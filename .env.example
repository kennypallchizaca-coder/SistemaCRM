# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno requeridas por el proyecto
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como `.env.local` y rellena los valores.
# Las variables con prefijo VITE_ se exponen al bundle del cliente.

# URL base del backend Strapi. En produccion debe ser la URL publica HTTPS.
VITE_API_BASE_URL=http://localhost:1337/api

# Entorno de ejecución (development | staging | production)
VITE_APP_ENV=development

# Nombre de la aplicación
VITE_APP_NAME=Carrera de Computación UPS
